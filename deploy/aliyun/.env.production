# ═══════════════════════════════════════════
# 北京K12英语AI家教 — 阿里云生产环境配置
# 复制此文件为 /opt/beijing-tutor/.env 并修改
# ═══════════════════════════════════════════

# 服务端口
PORT=3000

# 运行环境
NODE_ENV=production

# JWT 密钥（⚠️ 必须修改为随机字符串！）
# 生成方式: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string

# AI API 配置
ANTHROPIC_AUTH_TOKEN=sk-your-deepseek-api-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro

# 项目根目录
BASE_DIR=/opt/beijing-tutor

# Beta 邀请模式（上线初期建议开启）
INVITE_MODE=true

# 域名（用于SSL证书）
DOMAIN=beijingtutor.com

# ── 短信服务（腾讯云 SMS，可选）──
# SMS_SECRET_ID=
# SMS_SECRET_KEY=
# SMS_SDK_APP_ID=
# SMS_TEMPLATE_ID=
# SMS_SIGN_NAME=北京K12英语AI家教
