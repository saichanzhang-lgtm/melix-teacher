<div class="footer">—— 北京K12英语AI家教平台 · 专业教学资料 ——</div>
</body></html>`;
}

function exportDoc(section){
  if(!curMsgs().length){alert('请先生成内容再导出');return}
  const title=buildDocTitle(section);
  const html=buildWordHTML(section);
  const blob=new Blob(['﻿'+html],{type:'application/msword;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;
  a.download=title+'_'+new Date().toISOString().slice(0,10)+'.doc';
  document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);
}

// ═══════════════════════════════════════
// Messages (no flicker, per-agent)
// ═══════════════════════════════════════
function renderMessages(){
  const c=document.getElementById('asstMessages');
  c.innerHTML='';
  streamingEl=null;
  const msgs=curMsgs();
  msgs.forEach(m=>{const e=createMsgEl(m,false);c.appendChild(e);if(m.streaming)streamingEl=e});
  updateEmptyState();
  if(msgs.length)scrollToBottom();
}

function createMsgEl(msg,streaming){
  const d=document.createElement('div');d.className='msg '+msg.role;
  d.innerHTML='<div class="msg-avatar">'+(msg.role==='user'?'👤':'🎓')+'</div><div class="msg-content">'+renderMarkdown(msg.content)+(streaming?'<span class="loading-dots"><span></span><span></span><span></span></span>':'')+'</div>';
  return d;
}

function updateStreamingEl(content){
  if(streamingEl){const cd=streamingEl.querySelector('.msg-content');if(cd)cd.innerHTML=renderMarkdown(content)+'<span class="loading-dots"><span></span><span></span><span></span></span>';scrollToBottom()}
}

function scrollToBottom(){
  requestAnimationFrame(()=>{const c=document.getElementById('asstMessages');c.scrollTop=c.scrollHeight});
}

function addMessage(role,content,streaming=false){
  const msgs=curMsgs();
  if(streaming&&role==='assistant'&&msgs.length>0){const last=msgs[msgs.length-1];if(last.role==='assistant'&&last.streaming){last.content=content;updateStreamingEl(content);saveAll();return}}
  msgs.push({role,content,streaming});renderMessages();saveAll();
}

function finishStreaming(){
  const msgs=curMsgs();
  if(msgs.length>0)msgs[msgs.length-1].streaming=false;
  if(streamingEl){const cd=streamingEl.querySelector('.msg-content');if(cd&&msgs.length>0)cd.innerHTML=renderMarkdown(msgs[msgs.length-1].content);streamingEl=null}
  saveAll();
}

