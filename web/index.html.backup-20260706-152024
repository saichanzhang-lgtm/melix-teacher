  if(sess.ocrText)msg+='\n\n[试卷内容]\n'+sess.ocrText;
  document.getElementById('userInput').value=msg;sendMessage();
  setTimeout(()=>{if(btn){btn.textContent='🔬 开始批改';btn.disabled=false}},2000);
}

