function toggleGrammar(item,el){
  if(!cur().selected)cur().selected=[];
  const selected=cur().selected;
  const idx=selected.indexOf(item);
  if(idx>=0)selected.splice(idx,1);else selected.push(item);
  el.classList.toggle('selected');
  updateGrammarCount();
  cur().chatId=Date.now();saveAll();
}

function updateGrammarCount(){
  if(!cur().selected)cur().selected=[];
  const cnt=cur().selected.length;
  const btn=document.getElementById('grammarApplyBtn');
  const lbl=document.getElementById('grammarCount');
  if(lbl)lbl.textContent=cnt>0?'（已选'+cnt+'项）':'';
  if(btn)btn.textContent=cnt>0?'📐 组合出题（已选'+cnt+'项：'+cur().selected.join('、')+'）':'📐 请点击选择语法点';
}

