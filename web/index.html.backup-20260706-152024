function restoreConfigState(agent){
  setTimeout(()=>{
    if(agent==='teaching'){
      if(state.teaching.stage){const s=document.getElementById('teachStage');if(s){s.value=state.teaching.stage;updateTeaching()}}
      if(state.teaching.publisher){const s=document.getElementById('teachPublisher');if(s)s.value=state.teaching.publisher}
      if(state.teaching.grade){const s=document.getElementById('teachGrade');if(s)s.value=state.teaching.grade}
      if(state.teaching.semester){const s=document.getElementById('teachSemester');if(s)s.value=state.teaching.semester}
      if(state.teaching.unit){const s=document.getElementById('teachUnit');if(s)s.value=state.teaching.unit}
    }
    if(agent==='exam'){
      const sess=cur();
      if(sess.examType){const s=document.getElementById('examType');if(s)s.value=sess.examType}
      if(sess.score){const s=document.getElementById('examScore');if(s)s.value=sess.score}
      if(sess.duration){const s=document.getElementById('examDuration');if(s)s.value=sess.duration}
    }
    if(agent==='writing'){
      const sess=cur();
      if(sess.writeType){const s=document.getElementById('writingType');if(s)s.value=sess.writeType}
      if(sess.writeAction){const s=document.getElementById('writingAction');if(s)s.value=sess.writeAction}
    }
    if(agent==='grammar')updateGrammarCount();
    const el=document.getElementById('wsConfig');
    el.style.maxHeight='none';
    requestAnimationFrame(()=>{el.style.maxHeight=el.scrollHeight+'px'});
  },80);
}

