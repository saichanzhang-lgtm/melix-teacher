body{font-family:"Microsoft YaHei","微软雅黑","Times New Roman",serif;font-size:14px;line-height:1.5;color:#000;padding:0;margin:0}
.info-line{text-align:center;font-size:13px;margin:0 0 20px 0;border-bottom:1.5px solid #000;padding:0 0 12px 0}
