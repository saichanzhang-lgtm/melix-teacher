// Markdown
// ═══════════════════════════════════════
function renderMarkdown(text){
  if(!text)return'';
  let h=text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  h=h.replace(/```(\w*)\n?([\s\S]*?)```/g,'<pre><code>$2</code></pre>');
  h=h.replace(/`([^`]+)`/g,'<code>$1</code>');
  h=h.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
  h=h.replace(/\*([^*]+)\*/g,'<em>$1</em>');
  h=h.replace(/^#{3,4}\s(.+)$/gm,'<h3>$1</h3>');
  h=h.replace(/^##\s(.+)$/gm,'<h2>$1</h2>');
  h=h.replace(/^#\s(.+)$/gm,'<h1>$1</h1>');
  h=h.replace(/^&gt;\s?(.*)$/gm,'<blockquote>$1</blockquote>');
  h=h.replace(/<\/blockquote>\s*<blockquote>/g,'<br>');
  h=h.replace(/^(\s*)[-•]\s(.+)$/gm,'<li>$2</li>');
  h=h.replace(/((?:<li>.*<\/li>\s*)+)/g,'<ul>$1</ul>');
  h=h.replace(/<\/ul>\s*<ul>/g,'');
  h=h.replace(/^\|(.+)\|$/gm,m=>{const c=m.split('|').filter(x=>x.trim());if(m.includes('---'))return'';return'<tr>'+c.map(x=>'<td>'+x.trim()+'</td>').join('')+'</tr>'});
  h=h.replace(/((?:<tr>.*<\/tr>\s*)+)/g,'<table>$1</table>');
  h=h.replace(/\n\n/g,'</p><p>');
  h=h.replace(/\n/g,'<br>');
  h='<p>'+h+'</p>';
  h=h.replace(/<p>\s*<\/p>/g,'');
  return h;
}

// ═══════════════════════════════════════
// Clean text for Word export — strip AI chatter & markdown
// ═══════════════════════════════════════
const AI_CHATTER=[
  /^好的[，,。！!]?[\s\S]{0,50}$/gm,
  /^收到[，,。！!]?[\s\S]{0,50}$/gm,
  /^下面[我我们]?[开始将给来][\s\S]{0,80}$/gm,
  /^接下来[，,]?[我我们][\s\S]{0,80}$/gm,
  /^第一步[：:，,]?[\s\S]{0,80}$/gm,
  /^第二步[：:，,]?[\s\S]{0,80}$/gm,
  /^第三步[：:，,]?[\s\S]{0,80}$/gm,
  /^第[一二三四五六七八九]步[：:，,]?[\s\S]{0,80}$/gm,
  /^我建议[\s\S]{0,80}$/gm,
  /^我[将会][\s\S]{0,60}$/gm,
  /^现在[，,]?[我我们]?[\s\S]{0,80}$/gm,
  /^首先[，,]?[\s\S]{0,80}$/gm,
  /^然后[，,]?[\s\S]{0,80}$/gm,
  /^最后[，,]?[\s\S]{0,80}$/gm,
  /^请[注意放心][\s\S]{0,60}$/gm,
  /^以上[是就为][\s\S]{0,80}$/gm,
  /^希望[这以上][\s\S]{0,80}$/gm,
  /^如有[问题疑问][\s\S]{0,80}$/gm,
  /^祝你[\s\S]{0,60}$/gm,
  /^让我们[\s\S]{0,60}$/gm,
];

function cleanForWord(text){
  let t=text;
  // Strip AI chatter lines
  AI_CHATTER.forEach(pat=>{t=t.replace(pat,'')});
  // Strip markdown formatting
  t=t.replace(/```[\s\S]*?```/g,m=>m.replace(/```\w*\n?/g,'').replace(/```/g,''));
  t=t.replace(/`([^`]+)`/g,'$1');
  t=t.replace(/\*\*([^*]+)\*\*/g,'$1');
  t=t.replace(/\*([^*]+)\*/g,'$1');
  t=t.replace(/_([^_]+)_/g,'$1');
  t=t.replace(/~([^~]+)~/g,'$1');
  t=t.replace(/^#{1,6}\s/gm,'');
  t=t.replace(/^&gt;\s?/gm,'');
  t=t.replace(/^>\s?/gm,'');
  t=t.replace(/^[─━—–\-*_=]{3,}\s*$/gm,'');
  t=t.replace(/[─━]/g,'-');
  // Remove repeated punctuation/artifacts
  t=t.replace(/[#*_~`]{2,}/g,'');
  // Normalize whitespace
  t=t.replace(/[ \t]{2,}/g,' ');
  t=t.replace(/\n{3,}/g,'\n\n');
  t=t.replace(/^\s*\n/gm,'\n');
  t=t.replace(/(\S)\n{2,}(\S)/g,'$1\n\n$2');
  return t.trim();
}

// ═══════════════════════════════════════
// WORD EXPORT — 三版分离 + 专业排版
// ═══════════════════════════════════════
function buildDocTitle(section){
  const now=new Date();
  const dateStr=now.getFullYear()+'年'+(now.getMonth()+1)+'月'+now.getDate()+'日';
  const agent=state.agent;
  const diff=state.difficulty||'';
  let prefix='';
  if(agent==='grammar'){
    const sel=state.sessions.grammar.selected||[];
    prefix=diff+'语法-'+((sel.length>0)?sel.join('、'):'综合');
  }else if(agent==='teaching'){
    const t=state.teaching;
    prefix=[diff,t.grade,t.publisher,t.semester,t.unit?'Unit'+t.unit:''].filter(Boolean).join('·');
  }else if(agent==='exam'){
    prefix=diff+(state.sessions.exam.examType||'英语试卷');
  }else if(agent==='writing'){
    prefix=diff+(state.sessions.writing.writeType||'英语作文');
  }else{prefix=diff||'英语';}
  const labels={exam:'试卷版',answer:'答案版',teacher:'教师版（含解析）'};
  return prefix+' — '+labels[section];
}

function buildWordHTML(section){
  const now=new Date().toLocaleString('zh-CN');
  const title=buildDocTitle(section);
  let content='';

  curMsgs().forEach(msg=>{
    if(msg.role!=='assistant')return;
    let text=msg.content;
    if(section==='exam'){
      // Extract 【试卷版】 block or use everything before 【答案版】
      const m=text.match(/【试卷版】([\s\S]*?)(?=【答案版】|【教师版】|$)/);
      content+=(m?m[1]:text)+'\n';
    }else if(section==='answer'){
      const m=text.match(/【答案版】([\s\S]*?)(?=【教师版】|$)/);
      content+=(m?m[1]:'')+'\n';
    }else if(section==='teacher'){
      const m=text.match(/【教师版】([\s\S]*)/);
      content+=(m?m[1]:text)+'\n';
    }
  });

  content=cleanForWord(content);
  if(!content.trim())content='（暂无内容，请在对话中先生成试题或教案）';

  return `<!DOCTYPE html><html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
<head><meta charset="utf-8"><title>${title}</title>
<style>
