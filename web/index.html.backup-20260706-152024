<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>北京K12英语AI家教平台</title>
<style>
  /* ═══════════════════════════════════════════
     V3 Teacher Workspace — 3-Column Layout
     Agent Nav | Workspace | AI Assistant
     ═══════════════════════════════════════════ */
  :root {
    --primary:#7C6BA0;--primary-light:#E9E4F7;--primary-dark:#5F4B8B;
    --primary-hover:#F7F4FB;--primary-active-bg:#ECE6FA;--primary-active-border:#CFC1F0;--primary-active-text:#5C4D91;
    --accent:#C4907A;--accent-light:#F5EDE9;
    --bg:#F9F8F6;--surface:#FFFFFF;--text:#1E1B18;
    --text-secondary:#8E8880;--border:#E8E8E8;
    --shadow:0 1px 2px rgba(0,0,0,.04);--shadow-lg:0 4px 16px rgba(0,0,0,.06);
    --radius:12px;--radius-sm:8px;--input-bg:#FAFAF8;
    --success:#7A9E7E;--success-bg:#EDF5EE;--warning:#C9B88C;--danger:#C4907A;
    --font-sm:0.85rem;--font-base:0.94rem;--font-lg:1.15rem;--font-xl:1.4rem;--font-2xl:1.6rem;
    --nav-width:300px;--asst-width:380px;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{font-size:17px}
  body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;
    background:var(--bg);color:var(--text);height:100vh;overflow:hidden;
    -webkit-font-smoothing:antialiased;
  }

  /* ═══════ LAYOUT: 2-Column ═══════ */
  .app{display:flex;height:100vh;overflow:hidden}
  /* Col 1: Teacher Sidebar (left, fixed width, resizable) */
  /* Col 2: AI Workspace (right, flex:1, fills remaining space) */

  /* ── Teacher Workspace Sidebar (Left) ── */
  .nav-sidebar{width:var(--nav-width);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;height:100vh;overflow:hidden}
  .nav-scroll{flex:1;overflow-y:auto;overflow-x:hidden;padding:0}

  /* Sidebar Header */
  .sb-header{padding:14px 16px 10px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)}
  .sb-logo{font-size:1.4rem;flex-shrink:0}
  .sb-title{font-size:0.82rem;font-weight:700;line-height:1.2;color:var(--text)}
  .sb-subtitle{font-size:0.65rem;color:var(--text-secondary)}

  /* Sidebar Section */
  .sb-section{padding:8px 0}
  .sb-section-header{display:flex;align-items:center;justify-content:space-between;padding:6px 16px 4px}
  .sb-section-label{font-size:0.62rem;text-transform:uppercase;letter-spacing:0.6px;color:var(--text-secondary);font-weight:600}
  .sb-section-btn{font-size:0.7rem;background:none;border:none;color:var(--primary);cursor:pointer;padding:2px 6px;border-radius:4px;font-family:inherit}
  .sb-section-btn:hover{background:var(--primary-hover)}

  /* Student Card */
  .sb-student-card{margin:4px 10px;padding:10px 12px;background:var(--input-bg);border-radius:var(--radius);border:1px solid var(--border);cursor:pointer;transition:all .15s}
  .sb-student-card:hover{border-color:var(--primary-active-border);background:var(--primary-hover)}
  .sb-student-top{display:flex;align-items:center;gap:8px;margin-bottom:6px}
  .sb-student-avatar{width:32px;height:32px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:0.95rem;flex-shrink:0}
  .sb-student-name{font-size:0.82rem;font-weight:600;color:var(--text)}
  .sb-student-meta{font-size:0.65rem;color:var(--text-secondary);line-height:1.4}
  .sb-student-progress{margin-top:6px;display:flex;align-items:center;gap:6px}
  .sb-progress-bar{flex:1;height:4px;background:var(--border);border-radius:2px;overflow:hidden}
  .sb-progress-fill{height:100%;background:var(--primary);border-radius:2px;transition:width .3s}
  .sb-progress-label{font-size:0.6rem;color:var(--text-secondary);white-space:nowrap}
  .sb-no-student{padding:8px 14px;font-size:0.72rem;color:var(--text-secondary);text-align:center}

  /* Agent List */
  .sb-agent-item{display:flex;align-items:center;gap:10px;width:100%;padding:9px 16px;border:none;border-left:3px solid transparent;background:transparent;cursor:pointer;font-size:0.8rem;color:var(--text);transition:all .15s ease;font-family:inherit;text-align:left;-webkit-tap-highlight-color:transparent}
  .sb-agent-item:hover{background:var(--primary-hover);color:var(--primary-dark)}
  .sb-agent-item.active{background:var(--primary-active-bg);border-left-color:var(--primary);color:var(--primary-active-text);font-weight:600}
  .sb-agent-icon{font-size:1.1rem;width:24px;text-align:center;flex-shrink:0}
  .sb-agent-label{flex:1;line-height:1.3}
  .sb-agent-badge{font-size:0.6rem;padding:2px 6px;border-radius:8px;background:var(--primary-light);color:var(--primary-dark);white-space:nowrap}

  /* Conversation Items */
  .sb-conv-item{display:flex;align-items:center;gap:8px;padding:6px 16px 6px 20px;cursor:pointer;font-size:0.76rem;color:var(--text);transition:all .12s;font-family:inherit;border:none;background:none;width:100%;text-align:left;line-height:1.3;border-radius:0}
  .sb-conv-item:hover{background:var(--primary-hover)}
  .sb-conv-item.active{background:var(--primary-active-bg);color:var(--primary-active-text)}
  .sb-conv-icon{font-size:0.7rem;flex-shrink:0;opacity:.6}
  .sb-conv-title{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .sb-conv-time{font-size:0.6rem;color:var(--text-secondary);flex-shrink:0}
  .sb-conv-actions{display:none;gap:2px}
  .sb-conv-item:hover .sb-conv-actions{display:flex}
  .sb-conv-act-btn{font-size:0.65rem;background:none;border:none;cursor:pointer;padding:1px 4px;border-radius:3px;color:var(--text-secondary)}
  .sb-conv-act-btn:hover{background:var(--border);color:var(--text)}

  /* Settings */
  .sb-setting-item{display:flex;align-items:center;gap:8px;width:100%;padding:7px 16px;border:none;background:transparent;cursor:pointer;font-size:0.72rem;color:var(--text-secondary);transition:all .12s;font-family:inherit;text-align:left}
  .sb-setting-item:hover{background:var(--primary-hover);color:var(--text)}
  .sb-setting-icon{font-size:0.85rem;width:20px;text-align:center;flex-shrink:0}

  /* Resizer (sidebar right edge) */
  .sb-resizer{width:4px;cursor:col-resize;background:transparent;flex-shrink:0;position:relative;z-index:10;transition:background .15s}
  .sb-resizer:hover,.sb-resizer.dragging{background:var(--primary)}
  .sb-resizer::after{content:'';position:absolute;top:0;bottom:0;left:-3px;right:-3px}

  /* ── Workspace (Center) ── */
  .workspace{flex:1;display:flex;flex-direction:column;min-width:0;background:var(--bg);height:100vh;overflow:hidden}
  .ws-header{display:flex;align-items:center;gap:10px;padding:10px 16px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap}
  .ws-agent-badge{font-size:var(--font-sm);font-weight:600;padding:4px 12px;border-radius:20px;background:var(--primary-active-bg);color:var(--primary-active-text);white-space:nowrap}
  .ws-student-badge,.ws-diff-badge{font-size:0.78rem;color:var(--text-secondary);white-space:nowrap}
  .ws-header-actions{margin-left:auto;display:flex;gap:6px}
  .ws-btn{padding:5px 12px;border:1px solid var(--border);border-radius:16px;background:var(--surface);cursor:pointer;font-size:0.78rem;font-family:inherit;transition:all .15s;white-space:nowrap;color:var(--text)}
  .ws-btn:hover{background:var(--success-bg);border-color:var(--success);color:var(--success)}
  .ws-config{background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;overflow:hidden;transition:max-height .3s}
  .ws-config-inner{padding:12px 16px}
  .ws-content{flex:1 1 0;overflow-y:auto;overflow-x:hidden;padding:16px 20px;min-height:0}

  /* ── Workspace Toolbar ── */
  .ws-toolbar{display:flex;align-items:center;justify-content:space-between;padding:6px 12px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;gap:6px}
  .ws-tb-left{display:flex;align-items:center;gap:8px}
  .ws-tb-title{font-size:0.78rem;font-weight:600;color:var(--text)}
  .ws-tb-badge{font-size:0.62rem;padding:2px 8px;border-radius:10px;background:var(--primary-light);color:var(--primary-dark)}
  .ws-tb-right{display:flex;align-items:center;gap:4px;flex-wrap:wrap}
  .ws-tb-btn{font-size:0.7rem;padding:4px 10px;border:1px solid var(--border);border-radius:12px;background:var(--surface);cursor:pointer;font-family:inherit;color:var(--text);transition:all .12s;white-space:nowrap}
  .ws-tb-btn:hover{background:var(--primary-hover);border-color:var(--primary-active-border)}
  .ws-tb-btn.active{background:var(--primary-active-bg);border-color:var(--primary);color:var(--primary-active-text)}
  .ws-tb-sep{width:1px;height:16px;background:var(--border);margin:0 4px}

  /* ── Document View ── */
  .ws-doc-view{flex:1;overflow-y:auto;padding:0}

  /* ── Config & Grammar ── */
  .cfg-title{font-size:var(--font-base);font-weight:700;margin-bottom:8px;color:var(--text)}
  .cfg-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px}
  .cfg-select{padding:7px 10px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:var(--font-sm);background:var(--surface);font-family:inherit;cursor:pointer;color:var(--text)}
  .cfg-btn{padding:8px 18px;border:none;border-radius:var(--radius-sm);background:var(--primary);color:#fff;font-size:var(--font-sm);cursor:pointer;font-family:inherit;transition:all .15s}
  .cfg-btn:hover{filter:brightness(1.08)}
  .grammar-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(88px,1fr));gap:5px}
  .grammar-cat{font-size:0.72rem;font-weight:700;color:var(--text-secondary);grid-column:1/-1;margin-top:6px}
  .grammar-item{padding:7px 4px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:0.8rem;text-align:center;cursor:pointer;transition:all .15s;background:var(--surface);user-select:none}
  .grammar-item:hover{background:var(--primary-hover);border-color:var(--primary-active-border)}
  .grammar-item.selected{background:var(--primary-active-bg);color:var(--primary-active-text);border-color:var(--primary-active-border)}
  .upload-zone{border:2px dashed var(--border);border-radius:var(--radius);padding:20px;text-align:center;cursor:pointer;transition:all .2s;background:var(--input-bg)}
  .upload-zone:hover{border-color:var(--primary);background:var(--primary-hover)}
  .upload-zone input{display:none}
  .upload-result{margin-top:8px;padding:8px;background:#EDF5EE;border-radius:var(--radius-sm);font-size:0.8rem;display:none}

  /* ── Workspace content cards ── */
  .ws-doc-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px 28px;box-shadow:var(--shadow);max-width:800px;margin:0 auto;line-height:1.8;font-size:var(--font-base)}
  .ws-doc-card h1{font-size:var(--font-2xl);margin-bottom:12px}
  .ws-doc-card h2{font-size:var(--font-xl);margin:16px 0 8px}
  .ws-doc-card h3{font-size:var(--font-lg);margin:12px 0 6px}
  .ws-doc-card table{border-collapse:collapse;width:100%;margin:10px 0}
  .ws-doc-card th,.ws-doc-card td{border:1px solid var(--border);padding:6px 10px;text-align:left;font-size:var(--font-sm)}
  .ws-doc-card th{background:var(--input-bg);font-weight:600}
  .ws-doc-card pre{background:#F3F0FA;padding:12px;border-radius:var(--radius-sm);overflow-x:auto;font-size:0.85rem}
  .ws-doc-card code{background:var(--input-bg);padding:1px 4px;border-radius:4px;font-size:0.85rem}

  /* ── AI Workspace (Right — fills remaining space) ── */
  .asst-panel{flex:1;background:var(--surface);border-left:1px solid var(--border);display:flex;flex-direction:column;min-width:0;height:100vh}
  .asst-header{padding:10px 16px;border-bottom:1px solid var(--border);font-size:var(--font-sm);font-weight:600;color:var(--text);display:flex;align-items:center;gap:8px;flex-shrink:0;flex-wrap:wrap}
  .asst-header-dot{width:7px;height:7px;border-radius:50%;background:var(--success)}
  .asst-header-actions{margin-left:auto;display:flex;gap:6px}
  .asst-messages{flex:1 1 0;overflow-y:auto;overflow-x:hidden;padding:12px 14px;display:flex;flex-direction:column;gap:10px;min-height:0}
  .asst-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:var(--text-secondary);padding:20px}
  .asst-empty-icon{font-size:2.2rem;margin-bottom:8px}
  .asst-empty h3{font-size:var(--font-base);color:var(--text);margin-bottom:4px}
  .asst-empty p{font-size:0.82rem}
  .asst-input-wrap{display:flex;gap:8px;padding:10px 12px;border-top:1px solid var(--border);align-items:flex-end;flex-shrink:0;background:var(--surface)}
  .asst-input-wrap textarea{flex:1;padding:10px 14px;border:1px solid var(--border);border-radius:18px;font-size:var(--font-sm);resize:none;outline:none;font-family:inherit;background:var(--input-bg);max-height:100px;transition:border-color .2s;color:var(--text)}
  .asst-input-wrap textarea:focus{border-color:var(--primary)}
  .asst-send{width:36px;height:36px;border-radius:50%;border:none;background:var(--primary);color:#fff;font-size:1.1rem;cursor:pointer;flex-shrink:0;transition:all .2s;display:flex;align-items:center;justify-content:center}
  .asst-send:hover{filter:brightness(1.1);transform:scale(1.05)}
  .asst-send:disabled{opacity:.4;cursor:not-allowed;transform:none;filter:none}

  /* ── Messages ── */
  .msg{display:flex;gap:8px;max-width:92%;animation:fadeIn .2s ease-out}
  @keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
  .msg.user{align-self:flex-end;flex-direction:row-reverse}
  .msg.assistant{align-self:flex-start}
  .msg-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.85rem;flex-shrink:0}
  .msg.user .msg-avatar{background:var(--primary-light)}
  .msg.assistant .msg-avatar{background:var(--accent-light)}
  .msg-content{background:var(--surface);padding:10px 14px;border-radius:var(--radius);box-shadow:var(--shadow);line-height:1.7;font-size:var(--font-sm);word-break:break-word;border:1px solid var(--border)}
  .msg.user .msg-content{background:var(--primary-dark);color:#fff;border-color:var(--primary-dark)}
  .msg-content h2{font-size:var(--font-base);margin:6px 0 3px;font-weight:700}
  .msg-content h3{font-size:var(--font-sm);margin:5px 0 3px;font-weight:700}
  .msg-content p{margin-bottom:4px}.msg-content p:last-child{margin-bottom:0}
  .msg-content ul,.msg-content ol{padding-left:18px;margin:3px 0}
  .msg-content li{margin-bottom:2px}
  .msg-content table{border-collapse:collapse;width:100%;margin:5px 0;font-size:0.75rem;overflow-x:auto;display:block}
  .msg-content th,.msg-content td{border:1px solid var(--border);padding:3px 6px;text-align:left}
  .msg-content th{background:var(--input-bg);font-weight:600}
  .msg-content code{background:var(--input-bg);padding:1px 4px;border-radius:3px;font-size:0.78rem}
  .msg-content pre{background:#F3F0FA;padding:8px;border-radius:var(--radius-sm);overflow-x:auto;margin:4px 0;font-size:0.78rem;line-height:1.4}
  .msg-content strong{color:var(--primary-dark)}
  .msg.user .msg-content strong{color:#F5EDE9}
  .msg-content blockquote{border-left:2px solid var(--primary);padding-left:8px;margin:4px 0;color:var(--text-secondary)}

  /* ── Resizer ── */
  .asst-resizer{width:5px;cursor:col-resize;background:transparent;flex-shrink:0;position:relative;z-index:10;transition:background .15s}
  .asst-resizer:hover,.asst-resizer.dragging{background:var(--primary)}
  .asst-resizer::after{content:'';position:absolute;top:0;bottom:0;left:-4px;right:-4px}

  /* ── Debug Bar ── */
  .debug-bar{display:flex;align-items:center;gap:8px;padding:3px 12px;background:#2D2A27;color:#fff;font-size:0.7rem;font-family:monospace}
  .debug-dot{width:7px;height:7px;border-radius:50%;background:#FFC107;flex-shrink:0}
  .debug-dot.ok{background:#4CAF50}.debug-dot.err{background:#F44336}
  .protocol-warning{display:none;background:#FFF3CD;color:#856404;padding:8px 16px;text-align:center;font-size:0.85rem;border-bottom:2px solid #FFC107;line-height:1.6}
  .protocol-warning.show{display:block}
  .protocol-warning a{color:#664D03;font-weight:700}

  /* ── Loading dots ── */
  .loading-dots{display:flex;gap:3px;padding:3px 0}
  .loading-dots span{width:5px;height:5px;border-radius:50%;background:var(--text-secondary);animation:bounce 1.4s infinite ease-in-out both}
  .loading-dots span:nth-child(1){animation-delay:-.32s}
  .loading-dots span:nth-child(2){animation-delay:-.16s}
  @keyframes bounce{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}

  /* ── Overlay ── */
  .nav-overlay{display:none}

  /* ── Mobile ── */
  @media(max-width:900px){
    :root{--asst-width:100vw;--nav-width:56px}
    .asst-panel{position:fixed;top:0;right:0;bottom:0;z-index:300;transform:translateX(100%);transition:transform .25s;width:100vw;box-shadow:-4px 0 20px rgba(0,0,0,.15)}
    .asst-panel.open{transform:translateX(0)}
    .asst-resizer{display:none}
    .workspace{min-width:0}
    .nav-overlay{display:block;position:fixed;inset:0;z-index:299;background:rgba(0,0,0,.3);opacity:0;pointer-events:none;transition:opacity .25s}
    .nav-overlay.show{opacity:1;pointer-events:auto}
    .ws-doc-card{max-width:100%}
  }
</style>
</head>
<body>

<div class="protocol-warning" id="protocolWarning">
  ⚠️ <strong>检测到你直接打开了文件</strong>（地址栏是 <code>file:///</code>）<br>
  👉 请在浏览器地址栏输入：<a href="http://localhost:3000">http://localhost:3000</a> 访问平台
</div>

<div class="debug-bar" id="debugBar">
  <span class="debug-dot" id="debugDot"></span>
  <span id="debugMsg">V3 Teacher Workspace 启动中...</span>
</div>

<!-- ═══════════════ V3 TEACHER WORKSPACE ═══════════════ -->
<div class="app">
  <div class="nav-overlay" id="navOverlay"></div>

  <!-- Col 1: Teacher Workspace Sidebar -->
  <nav class="nav-sidebar" id="navSidebar">
    <div class="sb-header">
      <span class="sb-logo">🎓</span>
      <div><div class="sb-title">北京K12英语AI家教</div><div class="sb-subtitle">Teacher Workspace</div></div>
    </div>

    <div class="nav-scroll" id="navScroll">
      <!-- Student Card -->
      <div class="sb-section">
        <div class="sb-section-header">
          <span class="sb-section-label">🎯 当前学生</span>
          <button class="sb-section-btn" onclick="cycleStudent()" title="切换学生">切换</button>
        </div>
        <div id="sbStudentCard" class="sb-student-card" onclick="cycleStudent()">
          <div class="sb-no-student">点击选择学生 →</div>
        </div>
      </div>

      <!-- Agent Workspace -->
      <div class="sb-section">
        <div class="sb-section-header">
          <span class="sb-section-label">📚 AI 工作台</span>
        </div>
        <button class="sb-agent-item active" data-agent="teaching" onclick="switchAgent('teaching',this)">
          <span class="sb-agent-icon">📚</span><span class="sb-agent-label">教材教学</span><span class="sb-agent-badge">备课</span>
        </button>
        <button class="sb-agent-item" data-agent="grammar" onclick="switchAgent('grammar',this)">
          <span class="sb-agent-icon">📐</span><span class="sb-agent-label">语法中心</span><span class="sb-agent-badge">刷题</span>
        </button>
        <button class="sb-agent-item" data-agent="exam" onclick="switchAgent('exam',this)">
          <span class="sb-agent-icon">📋</span><span class="sb-agent-label">智能组卷</span><span class="sb-agent-badge">出卷</span>
        </button>
        <button class="sb-agent-item" data-agent="grade" onclick="switchAgent('grade',this)">
          <span class="sb-agent-icon">🔬</span><span class="sb-agent-label">智能阅卷</span><span class="sb-agent-badge">批改</span>
        </button>
        <button class="sb-agent-item" data-agent="writing" onclick="switchAgent('writing',this)">
          <span class="sb-agent-icon">✍️</span><span class="sb-agent-label">作文中心</span><span class="sb-agent-badge">写作</span>
        </button>
      </div>

      <!-- Current Agent Sessions -->
      <div class="sb-section">
        <div class="sb-section-header">
          <span class="sb-section-label">💬 当前会话</span>
          <button class="sb-section-btn" onclick="newConversation()" title="新建会话">➕ 新建</button>
        </div>
        <div id="sbConvList">
          <div class="sb-no-student">暂无会话记录</div>
        </div>
      </div>

      <!-- Settings -->
      <div class="sb-section">
        <div class="sb-section-header">
          <span class="sb-section-label">⚙ 工具与设置</span>
        </div>
        <button class="sb-setting-item" onclick="toggleKBDashboard()">
          <span class="sb-setting-icon">📊</span>知识库状态
        </button>
        <button class="sb-setting-item" onclick="cycleDifficulty()">
