// ── Grade ──
function handleFileUpload(evt){
  const file=evt.target.files[0];if(!file)return;
  cur().uploadedFile=file;
  const r=document.getElementById('uploadResult');r.style.display='block';r.textContent='✅ 已上传：'+file.name+' ('+(file.size/1024).toFixed(1)+' KB)';
  if(file.type==='text/plain'||file.name.endsWith('.txt')){
    const reader=new FileReader();
    reader.onload=e=>{cur().ocrText=e.target.result;const ta=document.getElementById('gradeOcrText');if(ta)ta.value=e.target.result;saveAll()};
    reader.readAsText(file);
  }
  saveAll();
}
function applyGrade(){
  const btn=document.querySelector('#agentConfig .cfg-btn');if(btn){btn.textContent='⏳ 批改中...';btn.disabled=true}
