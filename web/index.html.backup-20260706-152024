// ═══════════════════════════════════════
// Resizable Sidebar
// ═══════════════════════════════════════
(function(){
  const sidebar=document.getElementById('navSidebar');
  const sbResizer=document.getElementById('sbResizer');
  let sbDragging=false,sbStartX=0,sbStartW=0;
  const savedSbW=localStorage.getItem('nav_width');
  if(savedSbW&&sidebar){sidebar.style.width=savedSbW+'px';document.documentElement.style.setProperty('--nav-width',savedSbW+'px')}
  sbResizer.addEventListener('mousedown',function(e){
    sbDragging=true;sbStartX=e.clientX;sbStartW=sidebar.offsetWidth;
    sbResizer.classList.add('dragging');
    document.body.style.cursor='col-resize';document.body.style.userSelect='none';
    e.preventDefault();
  });
  document.addEventListener('mousemove',function(e){
    if(!sbDragging)return;
    let newW=sbStartW+(e.clientX-sbStartX);
    newW=Math.max(240,Math.min(400,newW));
    sidebar.style.width=newW+'px';
    document.documentElement.style.setProperty('--nav-width',newW+'px');
  });
  document.addEventListener('mouseup',function(){
    if(!sbDragging)return;
    sbDragging=false;sbResizer.classList.remove('dragging');
    document.body.style.cursor='';document.body.style.userSelect='';
    localStorage.setItem('nav_width',sidebar.offsetWidth);
  });
})();

