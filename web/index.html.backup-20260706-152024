// Send Message
// ═══════════════════════════════════════
async function sendMessage(){
  debug('sendMessage 被调用...','ok');
  const input=document.getElementById('userInput');
  const text=input.value.trim();
  if(!text){debug('输入为空，取消','err');return}
  if(state.isLoading){debug('⚠️ isLoading卡住，强制重置','err');state.isLoading=false}
  input.value='';input.style.height='auto';
  document.getElementById('sendBtn').disabled=true;state.isLoading=true;
  debug('状态已锁定，准备发送...','ok');

  const safetyTimer=setTimeout(()=>{if(state.isLoading){debug('⏰ 60秒超时，强制重置','err');state.isLoading=false;document.getElementById('sendBtn').disabled=false}},60000);

  try{
    const cfgPanel=document.getElementById('wsConfig');
    if(cfgPanel)cfgPanel.style.maxHeight='0';

    addMessage('user',text);

    let ctx='【重要规则】1.禁止生成依赖图片的题目（看图/图片阅读/图片选择/图片匹配均禁止）2.知识严格模式：仅基于教材和真题知识库回答，不存在的知识点请明确说"当前知识库暂无该内容"，禁止编造。\n';
    if(state.difficulty)ctx+='[难度：'+state.difficulty+'。请严格按此难度调整内容。]\n';
    if(state.student==='nandy')ctx+='[学生：Nandy，昌平区六年级小升初，人教版PEP]\n';
    else if(state.student==='yiyi')ctx+='[学生：熠熠，海淀区初一，初二提前学，人教版]\n';
    if(ctx)ctx+='\n';

    const userContent=ctx+text;
    const msgs=curMsgs();
    const apiMsgs=[];
    for(let i=Math.max(0,msgs.length-21);i<msgs.length-1;i++){
      if(!msgs[i].streaming)apiMsgs.push({role:msgs[i].role,content:msgs[i].content});
    }
    apiMsgs.push({role:'user',content:userContent});

    addMessage('assistant','',true);
    debug('正在请求 API ('+AGENT_NAMES[state.agent]+')...','ok');

    const resp=await fetch('/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({messages:apiMsgs})});
    debug('收到响应 HTTP '+resp.status,'ok');
    if(!resp.ok){const err=await resp.json().catch(()=>({error:'HTTP '+resp.status}));throw new Error(err.error||'请求失败')}
    const reader=resp.body.getReader();const decoder=new TextDecoder();let full='',buf='';
    while(true){
      const{done,value}=await reader.read();if(done)break;
      buf+=decoder.decode(value,{stream:true});
      const lines=buf.split('\n');buf=lines.pop()||'';
      for(const line of lines){
        if(line.startsWith('data: ')){
          try{const d=JSON.parse(line.slice(6));if(d.type==='text'){full+=d.text;addMessage('assistant',full,true)}}catch(e){}
        }
      }
    }
    finishStreaming();
    // Auto-title conversation
    const active=getActiveConv();
    if(active&&active.messages.length>0)active.title=getConvTitle(active.messages);
    debug('✅ 生成完成 ('+full.length+' 字)','ok');
    renderConvList();
  }catch(e){
    finishStreaming();
    debug('❌ 错误: '+e.message,'err');
    const msgs2=curMsgs();
    let errMsg=e.message||'未知错误';
    if(errMsg.includes('Failed to fetch')||errMsg.includes('NetworkError'))errMsg='无法连接服务器，请在终端执行：cd D:/beijing-english-tutor/web && node server.js';
    if(msgs2.length>0){msgs2[msgs2.length-1]={role:'assistant',content:'❌ 出错了：'+errMsg,streaming:false}}
    else{msgs2.push({role:'assistant',content:'❌ 出错了：'+errMsg,streaming:false})}
    renderMessages();saveAll();
  }finally{
    clearTimeout(safetyTimer);
    state.isLoading=false;
    document.getElementById('sendBtn').disabled=false;
    document.getElementById('userInput').focus();
  }
}

function quickAsk(text){document.getElementById('userInput').value=text;sendMessage()}
