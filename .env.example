# Beijing K12 English AI Tutor — 环境变量配置
# 复制此文件为 .env 并填入真实值

# 服务端口
PORT=3000

# 运行环境: development | production
NODE_ENV=development

# JWT 密钥（生产环境请使用随机字符串）
JWT_SECRET=change-me-to-random-string-in-production

# AI API 配置
ANTHROPIC_AUTH_TOKEN=sk-your-api-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro

# Beta 邀请模式（true=需要邀请码才能注册）
INVITE_MODE=false

# 短信服务（生产环境需要接入腾讯云短信）
# SMS_SECRET_ID=
# SMS_SECRET_KEY=
# SMS_SDK_APP_ID=
# SMS_TEMPLATE_ID=
# SMS_SIGN_NAME=北京K12英语AI家教
